$ JFEM / Nastran HDF5 schema probe
$ Purpose: small mixed-element SOL 101 deck for Nastran HDF5 structure discovery.
$ MSC/Nastran 2021 HDF5 output is requested in bulk with MDLPRM,HDF5,1.
$ PLOT is included in result requests so HyperView can read the .h5 database.
SOL 101
CEND
TITLE = JFEM HDF5 SCHEMA PROBE - SOL101
ECHO = NONE
SUBCASE 1
  SUBTITLE = MIXED ELEMENT STATIC RESPONSE
  SPC = 1
  LOAD = 10
  DISPLACEMENT(SORT1,REAL,PLOT,PRINT,PUNCH) = ALL
  SPCFORCES(SORT1,REAL,PLOT,PRINT,PUNCH) = ALL
  MPCFORCES(SORT1,REAL,PLOT,PRINT,PUNCH) = ALL
  OLOAD(SORT1,REAL,PLOT,PRINT,PUNCH) = ALL
  FORCE(SORT1,REAL,BILIN,PLOT,PRINT,PUNCH) = ALL
  STRESS(SORT1,REAL,VONMISES,BILIN,PLOT,PRINT,PUNCH) = ALL
  STRAIN(SORT1,REAL,VONMISES,BILIN,PLOT,PRINT,PUNCH) = ALL
